# --- Required ---

# Anthropic API key (get one from https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Prisma datasource URL. SQLite locale; i query params sono parametrizzati per
# rendere il file riutilizzabile dopo lo swap a Postgres senza modifiche.
DATABASE_URL="file:./dev.db?connection_limit=1&socket_timeout=5"

# Numero massimo di chiamate Claude in volo simultaneamente. Default 4 in locale.
CLAUDE_MAX_CONCURRENT=4

# --- Optional, per Phase 2 (data sources reali) ---
# Quando una di queste è settata, il rispettivo stub data-source userà l'API
# reale invece del fallback web search Anthropic.

# APIFY_TOKEN=          # Phase 2 — Apify actors (TikTok, Shopify stores, AliExpress)
# META_ACCESS_TOKEN=    # Phase 2 — Meta Ad Library
# SERPAPI_KEY=          # Phase 2 — Google Trends via SerpAPI / DataForSEO
# KEEPA_KEY=            # Phase 2 — Amazon BSR / pricing via Keepa
